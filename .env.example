# Azure OpenAI Configuration
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=your_default_deployment_name
AZURE_OPENAI_DEPLOYMENT_CLAUSE_EXTRACTOR=your_clause_extractor_deployment_name
AZURE_OPENAI_DEPLOYMENT_OBLIGATION_FINDER=your_obligation_finder_deployment_name
AZURE_OPENAI_DEPLOYMENT_RISK_SCORER=your_risk_scorer_deployment_name
AZURE_OPENAI_DEPLOYMENT_RED_FLAG_DETECTOR=your_red_flag_detector_deployment_name
AZURE_OPENAI_DEPLOYMENT_PLAIN_ENGLISH_WRITER=your_plain_english_writer_deployment_name
AZURE_OPENAI_DEPLOYMENT_REPORT_ASSEMBLER=your_report_assembler_deployment_name
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=your_embedding_deployment_name

# Azure AI Search Configuration
AZURE_SEARCH_ENDPOINT=https://your-search-resource.search.windows.net/
AZURE_SEARCH_API_KEY=your_azure_search_api_key_here
AZURE_SEARCH_INDEX_LEGAL=legal_index_name
AZURE_SEARCH_INDEX_CONTRACTS=contracts_index_name
AZURE_SEARCH_INDEX_REDFLAGS=redflags_index_name

# Azure Storage Configuration
AZURE_STORAGE_ACCOUNT_NAME=your_storage_account_name
AZURE_STORAGE_ACCOUNT_KEY=your_storage_account_key_here
AZURE_STORAGE_CONTAINER_NAME=your_container_name
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your_storage_account_name;AccountKey=your_storage_account_key_here;EndpointSuffix=core.windows.net

# Azure Document Intelligence Configuration
AZURE_DOC_INTELLIGENCE_ENDPOINT=https://your-doc-intelligence.cognitiveservices.azure.com/
AZURE_DOC_INTELLIGENCE_KEY=your_doc_intelligence_key_here

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_key_here

# LangFuse Configuration
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_HOST=https://cloud.langfuse.com
