# Default Azure OpenAI Configuration
AZURE_OPENAI_API_KEY=your_azure_openai_api_key_here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com/
AZURE_OPENAI_DEPLOYMENT_NAME=your_default_deployment_name
AZURE_OPENAI_DEPLOYMENT_CLAUSE_EXTRACTOR=your_clause_extractor_deployment_name
AZURE_OPENAI_DEPLOYMENT_OBLIGATION_FINDER=your_obligation_finder_deployment_name
AZURE_OPENAI_DEPLOYMENT_RISK_SCORER=your_risk_scorer_deployment_name
AZURE_OPENAI_DEPLOYMENT_RED_FLAG_DETECTOR=your_red_flag_detector_deployment_name
AZURE_OPENAI_DEPLOYMENT_PLAIN_ENGLISH_WRITER=your_plain_english_writer_deployment_name
AZURE_OPENAI_DEPLOYMENT_REPORT_ASSEMBLER=your_report_assembler_deployment_name
AZURE_OPENAI_EMBEDDING_DEPLOYMENT=your_embedding_deployment_name

# Agent-Specific LLM Configurations (Optional: override default endpoints/keys per agent)
# Format: AZURE_OPENAI_ENDPOINT_[AGENT_NAME], AZURE_OPENAI_API_KEY_[AGENT_NAME], AZURE_OPENAI_DEPLOYMENT_[AGENT_NAME]
# Supported agent names: CLAUSE_EXTRACTOR, OBLIGATION_FINDER, RISK_SCORER, RED_FLAG_DETECTOR, PLAIN_ENGLISH_WRITER, REPORT_ASSEMBLER, RELEVANCE_GATER
# Example:
# AZURE_OPENAI_ENDPOINT_RISK_SCORER=https://risk-scorer-resource.openai.azure.com/
# AZURE_OPENAI_API_KEY_RISK_SCORER=your_agent_specific_key
# AZURE_OPENAI_DEPLOYMENT_RISK_SCORER=GPT-4o

# Gemini / Google OpenAI Compatibility Configuration (e.g. for Relevance Gater)
# GEMINI_API_KEY=your_gemini_api_key_here
# AZURE_OPENAI_DEPLOYMENT_RELEVANCE_GATER=gemini-3.1-flash-lite

# Groq API Configuration (for rate limit mitigation fallbacks and routing)
# GROQ_API_KEY=your_groq_api_key_here
# GROQ_DEFAULT_MODEL=llama-3.3-70b-versatile


# Azure AI Search Configuration
AZURE_SEARCH_ENDPOINT=https://your-search-resource.search.windows.net/
AZURE_SEARCH_API_KEY=your_azure_search_api_key_here

# Azure Storage Configuration
AZURE_STORAGE_ACCOUNT_NAME=your_storage_account_name
AZURE_STORAGE_ACCOUNT_KEY=your_storage_account_key_here
AZURE_STORAGE_CONTAINER_NAME=your_container_name
AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=your_storage_account_name;AccountKey=your_storage_account_key_here;EndpointSuffix=core.windows.net

# Azure Document Intelligence Configuration
AZURE_DOC_INTELLIGENCE_ENDPOINT=https://your-doc-intelligence.cognitiveservices.azure.com/
AZURE_DOC_INTELLIGENCE_KEY=your_doc_intelligence_key_here

# Redis Configuration
REDIS_URL=redis://localhost:6379

# Supabase Configuration
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_key_here

# LangFuse Configuration
LANGFUSE_PUBLIC_KEY=your_langfuse_public_key_here
LANGFUSE_SECRET_KEY=your_langfuse_secret_key_here
LANGFUSE_HOST=https://cloud.langfuse.com

# --- Risk Scorer Configuration ---
# Maximum clauses processed by Risk Scorer (default: 50)
RISK_SCORER_MAX_CLAUSES=50
# Maximum characters allowed per clause in risk analysis prompt (default: 700)
RISK_SCORER_TEXT_TRUNCATION=700
# High risk overall score threshold (default: 0.6)
RISK_THRESHOLD_HIGH=0.6
# Medium risk overall score threshold (default: 0.3)
RISK_THRESHOLD_MEDIUM=0.3

# --- Agent LLM Token Limits ---
# Max tokens allowed for each agent's completion response (default: 4000)
CLAUSE_EXTRACTOR_MAX_TOKENS=4000
OBLIGATION_FINDER_MAX_TOKENS=4000
RED_FLAG_DETECTOR_MAX_TOKENS=4000
RISK_SCORER_MAX_TOKENS=4000
PLAIN_ENGLISH_WRITER_MAX_TOKENS=4000
REPORT_ASSEMBLER_MAX_TOKENS=4000

# --- Agent Data Limits ---
# Limit of clauses summarized in plain english fallback summary (default: 5)
PLAIN_ENGLISH_WRITER_CLAUSES_LIMIT=5
# Limit of clauses summarized in the final report metadata section (default: 15)
REPORT_ASSEMBLER_CLAUSES_LIMIT=15

# --- Tenacity Retry Settings ---
# Multiplier for exponential backoff (default: 1.0)
RETRY_MULTIPLIER=1.0
# Minimum wait time in seconds (default: 2.0)
RETRY_MIN_WAIT=2.0
# Maximum wait time in seconds (default: 30.0)
RETRY_MAX_WAIT=30.0
# Maximum retry attempts before failing (default: 5)
RETRY_MAX_ATTEMPTS=5

# --- Storage and Persistence ---
# Redis session caching TTL in seconds (default: 3600)
REDIS_TTL_SECONDS=3600
# Top-K documents to retrieve during RAG search (default: 5)
SEARCH_TOP_K=5

# Qdrant Configuration (Fallback Vector Database)
QDRANT_URL=http://localhost:6333
QDRANT_API_KEY=your_qdrant_api_key_here

# Memory & Gating Configuration
MEMORY_SHORT_TERM_TTL_SECONDS=3600
RELEVANCE_GATING_MAX_CHARS=1500

# Qdrant Collection Configuration
QDRANT_COLLECTION_NAME=contracts-memory

# Chat and Page Rendering Configuration
AZURE_OPENAI_DEPLOYMENT_VISION=your_vision_model_deployment_name  # e.g. gpt-4o
CHAT_MAX_HISTORY_TURNS=10
CHAT_TOP_K_CLAUSES=5
PAGE_IMAGE_DPI=300
STORE_PAGE_IMAGES=true

# Map-Reduce Configuration
AGENT_PROCESSING_CHUNK_SIZE=20


